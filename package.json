{
  "name": "mc-tools",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "Automation tools for Minecraft modpack development",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm run build:readme && pnpm -r run build",
    "build:readme": "tsx scripts/build/readme.ts",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:all": "pnpm -r --workspace-concurrency=1 --filter=!@mctools/utils --filter=!@mctools/extension exec -- semantic-release",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@mctools/eslint-plugin-zs": "workspace:*",
    "@mctools/format": "workspace:*",
    "@semantic-release/exec": "^7.0.3",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "eslint": "9.39.4",
    "ftbq-nbt": "^1.4.1",
    "handlebars": "^4.7.9",
    "lint-staged": "^15.5.2",
    "sanitize-filename": "^1.6.4",
    "semantic-release": "^24.2.9",
    "semantic-release-plugin-decorators": "^4.0.0",
    "tinyglobby": "^0.2.14",
    "ts-deepmerge": "^7.0.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "packages/*/package.json": "node merge_jsons.js",
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix --no-warn-ignored"
  }
}
