{
  "name": "mc-tools",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "Automation tools for Minecraft modpack development",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm run build:readme && pnpm -r run build",
    "build:readme": "tsx scripts/build/readme.ts",
    "test": "pnpm -r run test",
    "release:all": "pnpm -r --workspace-concurrency=1 exec -- npx --no-install semantic-release -e semantic-release-monorepo",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "consola": "^3.4.2",
    "ftbq-nbt": "^1.4.1",
    "handlebars": "^4.7.9",
    "lint-staged": "^15.5.2",
    "sanitize-filename": "^1.6.4",
    "semantic-release": "^24.2.9",
    "semantic-release-monorepo": "^8.0.2",
    "ts-deepmerge": "^7.0.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.4",
    "yargs": "^18.0.0"
  },
  "lint-staged": {
    "packages/*/package.json": "node merge_jsons.js",
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix --no-warn-ignored"
  },
  "workspaces": [
    "packages/*"
  ]
}
