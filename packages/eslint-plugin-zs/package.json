{
  "name": "@mctools/eslint-plugin-zs",
  "type": "module",
  "version": "0.1.0",
  "description": "ESLint plugin: lint and auto-format .zs (ZenScript) via @mctools/format",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "eslint",
    "eslint-plugin",
    "zenscript",
    "crafttweaker"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.mjs",
      "require": "./dist/config.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "coverage": "vitest run --coverage",
    "test": "vitest run"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@mctools/format": "workspace:*"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^9.39.4",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
