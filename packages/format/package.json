{
  "name": "@mctools/format",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Format .zs files by using ESLint for typescript",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "ci",
    "cli"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "mctools-format": "./src/cli.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild && cp src/parser-generated.mjs dist/parser-generated.mjs",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "build:parser": "node scripts/build-parser.mjs",
    "prebuild": "pnpm run build:parser",
    "pretest": "pnpm run build:parser"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "balanced-match": "^3.0.1",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "tinyglobby": "^0.2.14"
  },
  "devDependencies": {
    "@types/balanced-match": "^3.0.2",
    "eslint": "^9.39.4",
    "peggy": "^3.0.2"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "mctools-format": "./dist/cli.mjs"
    }
  }
}
