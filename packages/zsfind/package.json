{
  "name": "@mctools/zsfind",
  "type": "module",
  "version": "0.1.0",
  "description": "Look up ZenScript class definitions, fields and method signatures from CraftTweaker dumps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git",
    "directory": "packages/zsfind"
  },
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "crafttweaker",
    "zenscript",
    "cli"
  ],
  "bin": {
    "mctools-zsfind": "./src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "chalk": "^5.6.2",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "env-paths": "^4.0.0",
    "fast-glob": "^3.3.3",
    "fastest-levenshtein": "^1.0.16",
    "fs-extra": "^11.3.0",
    "pathe": "^1.1.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "mctools-zsfind": "./dist/cli.mjs"
    }
  },
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "test": "vitest run --passWithNoTests"
  }
}
