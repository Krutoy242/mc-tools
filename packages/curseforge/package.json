{
  "name": "@mctools/curseforge",
  "type": "module",
  "version": "0.1.0",
  "description": "Lib for working with CurseForge using minecraftinstance.json",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git",
    "directory": "packages/curseforge"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./minecraftinstance": {
      "types": "./dist/minecraftinstance.d.mts",
      "import": "./dist/minecraftinstance.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "curseforge-v2": "^1.2.0",
    "ignore": "^5.2.4"
  },
  "devDependencies": {},
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts"
}
