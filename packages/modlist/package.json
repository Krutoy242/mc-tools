{
  "name": "@mctools/modlist",
  "type": "module",
  "version": "0.1.2",
  "description": "Generate .md file with all mods listed",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git",
    "directory": "packages/modlist"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "ci",
    "cli",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "mctools-modlist": "./src/cli.ts"
  },
  "files": [
    "*.hbs",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mctools/curseforge": "workspace:*",
    "chalk": "^5.3.0",
    "citty": "^0.1.6",
    "handlebars": "^4.7.7"
  },
  "devDependencies": {
    "@mctools/utils": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "mctools-modlist": "./dist/cli.mjs"
    }
  }
}
