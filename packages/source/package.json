{
  "name": "@mctools/source",
  "type": "module",
  "version": "0.1.0",
  "description": "Locate, clone or decompile Minecraft mod source code",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git",
    "directory": "packages/source"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "ci",
    "cli"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "mctools-source": "./src/cli.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "coverage": "vitest run --coverage",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mctools/curseforge": "workspace:*",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "pathe": "^1.1.2",
    "yaml": "^2.5.1",
    "yargs": "^17.7.1",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.24",
    "@types/yauzl": "^2.10.3"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "mctools-source": "./dist/cli.mjs"
    }
  }
}
