{
  "name": "@mctools/utils",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Various utilities for Minecraft-Tools monorepo, intended to be bundled not dependent",
  "author": "Krutoy242 <Krutoy242@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Krutoy242/mc-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutoy242/mc-tools.git"
  },
  "bugs": "https://github.com/Krutoy242/mc-tools/issues",
  "keywords": [
    "automation",
    "minecraft",
    "tools",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./natural-sort": {
      "types": "./dist/natural-sort.d.mts",
      "import": "./dist/natural-sort.mjs"
    },
    "./args": {
      "types": "./dist/args.d.mts",
      "import": "./dist/args.mjs"
    },
    "./lang": {
      "types": "./dist/lang.d.mts",
      "import": "./dist/lang.mjs"
    },
    "./ftbquests": {
      "types": "./dist/mods/ftbquests.d.mts",
      "import": "./dist/mods/ftbquests.mjs"
    },
    "./tellme": {
      "types": "./dist/mods/tellme.d.mts",
      "import": "./dist/mods/tellme.mjs"
    },
    "./mod-resolve": {
      "types": "./dist/mods/resolve.d.mts",
      "import": "./dist/mods/resolve.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "csv-parse": "^5.0.0",
    "ftbq-nbt": "^1.4.1"
  },
  "peerDependenciesMeta": {
    "csv-parse": {
      "optional": true
    },
    "ftbq-nbt": {
      "optional": true
    }
  },
  "dependencies": {
    "consola": "^3.1.0",
    "tinyglobby": "^0.2.14"
  },
  "devDependencies": {
    "csv-parse": "^5.3.8",
    "ftbq-nbt": "^1.4.1"
  }
}
